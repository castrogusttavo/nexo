{
  "openapi": "3.1.0",
  "info": {
    "title": "Nexo API",
    "version": "1.0.0",
    "description": "API do Nexo — gestão ágil de projetos",
    "contact": {
      "name": "Coodee",
      "email": "suporte@coodee.dev"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Desenvolvimento Local"
    },
    {
      "url": "https://nexo.coodee.dev/api",
      "description": "Produção"
    }
  ],
  "paths": {
    "/auth/sign-up/email": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Criar conta com e-mail e senha",
        "description": "Cria uma nova conta de usuário usando e-mail e senha. Retorna sessão autenticada.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 2,
                    "example": "João Silva"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "joao@exemplo.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6,
                    "example": "senha123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conta criada e sessão iniciada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/sign-in/email": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login com e-mail e senha",
        "description": "Autentica o usuário e retorna sessão com cookie.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "joao@exemplo.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "senha123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas"
          }
        }
      }
    },
    "/auth/sign-out": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Encerrar sessão",
        "description": "Remove a sessão e limpa o cookie de autenticação.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Sessão encerrada com sucesso"
          }
        }
      }
    },
    "/auth/sign-in/social": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Login com provedor social (Google/GitHub)",
        "description": "Inicia o fluxo OAuth com o provedor especificado.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["provider", "callbackURL"],
                "properties": {
                  "provider": {
                    "type": "string",
                    "enum": ["google", "github"],
                    "example": "google"
                  },
                  "callbackURL": {
                    "type": "string",
                    "format": "uri",
                    "example": "https://nexo.coodee.dev"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retorna URL de redirect para o provedor OAuth"
          }
        }
      }
    },
    "/auth/get-session": {
      "get": {
        "tags": ["Autenticação"],
        "summary": "Obter sessão atual",
        "description": "Retorna os dados da sessão e do usuário autenticado via cookie.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Sessão ativa encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Nenhuma sessão ativa"
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Usuário"],
        "summary": "Obter perfil do usuário autenticado",
        "description": "Retorna os dados do perfil do usuário logado.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Perfil retornado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "success": true,
                  "statusCode": 200,
                  "data": {
                    "id": "clx1abc123",
                    "name": "João Silva",
                    "email": "joao@exemplo.com",
                    "emailVerified": true,
                    "image": null,
                    "role": "MEMBER",
                    "workspaceId": null,
                    "createdAt": "2026-01-01T00:00:00.000Z"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      },
      "patch": {
        "tags": ["Usuário"],
        "summary": "Atualizar perfil do usuário",
        "description": "Atualiza nome e/ou e-mail do usuário autenticado.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Perfil atualizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/send/welcome": {
      "post": {
        "tags": ["E-mails"],
        "summary": "Enviar e-mail de boas-vindas",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "username"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "username": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "E-mail enviado"
          },
          "500": {
            "description": "Falha no envio"
          }
        }
      }
    },
    "/send/confirm-email": {
      "post": {
        "tags": ["E-mails"],
        "summary": "Enviar e-mail de confirmação",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "E-mail enviado"
          },
          "500": {
            "description": "Falha no envio"
          }
        }
      }
    },
    "/send/reset-password": {
      "post": {
        "tags": ["E-mails"],
        "summary": "Enviar e-mail de redefinição de senha",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "E-mail enviado"
          },
          "500": {
            "description": "Falha no envio"
          }
        }
      }
    },
    "/send/invite-user": {
      "post": {
        "tags": ["E-mails"],
        "summary": "Enviar convite para usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Convite enviado"
          },
          "500": {
            "description": "Falha no envio"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "better-auth.session_token",
        "description": "Token de sessão gerenciado pelo Better Auth (cookie HttpOnly)"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "CUID do usuário",
            "example": "clx1abc123"
          },
          "name": {
            "type": "string",
            "example": "João Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao@exemplo.com"
          },
          "emailVerified": {
            "type": "boolean",
            "example": true
          },
          "image": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "role": {
            "type": "string",
            "enum": ["MEMBER", "ADMIN"],
            "example": "MEMBER"
          },
          "workspaceId": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-01-01T00:00:00.000Z"
          }
        }
      },
      "UpdateUserInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "example": "João Santos"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "joao.santos@exemplo.com"
          }
        }
      },
      "AuthSessionResponse": {
        "type": "object",
        "properties": {
          "session": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "userId": { "type": "string" },
              "token": { "type": "string" },
              "expiresAt": { "type": "string", "format": "date-time" }
            }
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "statusCode": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "statusCode": {
            "type": "integer",
            "example": 400
          },
          "message": {
            "type": "string"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "details": { "type": "object" }
            }
          }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "statusCode": {
            "type": "integer",
            "example": 422
          },
          "message": {
            "type": "string",
            "example": "Dados inválidos"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "VALIDATION_ERROR"
              },
              "details": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Não autenticado — sessão ausente ou expirada",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "statusCode": 401,
              "message": "Nao autenticado",
              "error": {
                "code": "UNAUTHORIZED"
              }
            }
          }
        }
      },
      "ValidationError": {
        "description": "Erro de validação dos dados enviados",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ValidationErrorResponse"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Autenticação",
      "description": "Sign-up, sign-in, sign-out e sessão (Better Auth)"
    },
    {
      "name": "Usuário",
      "description": "Perfil do usuário autenticado"
    },
    {
      "name": "E-mails",
      "description": "Envio de e-mails transacionais via Resend"
    }
  ]
}
