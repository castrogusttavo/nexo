{
  "name": "nexo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "infra": "pnpm docker:start && pnpm prisma:migrate:dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 44385",
    "check": "biome check --fix",
    "check:ci": "biome check",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:integration": "vitest --project integration",
    "test:e2e": "vitest --project e2e",
    "test:unit:watch": "vitest --project unit --watch",
    "test:unit:coverage": "vitest --project unit --coverage",
    "test:all": "vitest --run",
    "test:ci": "vitest --run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:deploy": "prisma migrate deploy",
    "docker:create": "docker compose -f docker-compose.infra.yml up -d",
    "docker:start": "docker compose -f docker-compose.infra.yml start",
    "docker:stop": "docker compose -f docker-compose.infra.yml stop",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "7.4.2",
    "@react-email/components": "^1.0.8",
    "@react-email/tailwind": "2.0.5",
    "@scalar/nextjs-api-reference": "^0.9.24",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "better-auth": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "frimousse": "^0.3.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.11.0",
    "resend": "^6.9.3",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@faker-js/faker": "^10.3.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "4.0.18",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "prisma": "7.4.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
